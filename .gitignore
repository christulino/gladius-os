# Dependencies (pattern without trailing slash also catches node_modules symlinks
# used by git worktrees that share the primary checkout's installed deps)
node_modules/
node_modules
admin-ui/node_modules

# Environment — never commit credentials
.env
.mcp.json

# macOS
.DS_Store

# Logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid

# Editor
.vscode/
.idea/

# Vite temp files
vite.config.js.timestamp-*

# Playwright MCP smoke artifacts (traces + screenshots)
.playwright-mcp/
*-screenshot.png
search-page-after-save.png
search-with-detail-drawer.png
/*.png

# Claude Code — commit settings.json (shared), ignore local overrides + runtime state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Local file uploads (attachments storage)
uploads/

# Visual brainstorming sessions
.superpowers/

# Internal session docs — never commit to public repo
_internal/
*_HANDOFF.md
ARCHITECTURE.md
CLAUDE.md
SESSION_*.md
STATE.md
BACKLOG.md
DECISIONS.md
PARKING_LOT.md
PRODUCT_PLAN.md
RISKS.md
QUESTIONS.md
TODO.md
docs/superpowers/
docs/plans/
docs/strategy/
feature_plans/
.claude/
