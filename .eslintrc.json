{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "ignorePatterns": [
    "node_modules/",
    "admin-ui/",
    "runtime/search/jql.parser.js"
  ],
  "rules": {
    "no-undef": "error",
    "no-unused-vars": ["error", {
      "args": "after-used",
      "argsIgnorePattern": "^_|^next$",
      "varsIgnorePattern": "^_",
      "caughtErrorsIgnorePattern": "^_"
    }],
    "no-unreachable": "error"
  }
}
