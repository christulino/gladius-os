# Gladius — environment configuration
# Copy to .env and fill in your values before starting the server.
# Lines marked REQUIRED must be set. Others have working defaults.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Dev-only surfaces (Raw Tables, DB Console, Log Viewer, Simulation) — off by
# default. Set to true to expose them in the nav and enable their API routes.
GLADIUS_DEV_TOOLS=false

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flowos
POSTGRES_USER=flowos
POSTGRES_PASSWORD=                   # REQUIRED
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# ── Auth ──────────────────────────────────────────────────────────────────────
SESSION_SECRET=                      # REQUIRED — at least 32 random characters

# ── AI / Playbooks ────────────────────────────────────────────────────────────
# Both keys are REQUIRED to use playbooks, the NL search translator, or any
# AI-driven feature. Without them the server starts but AI calls will fail.

# Your Anthropic API key — used by the playbook executor and NL search translator.
ANTHROPIC_API_KEY=                   # REQUIRED for AI features

# 32-byte hex key for AES-256-GCM encryption of AI model API keys stored in the DB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GLADIUS_ENCRYPTION_KEY=              # REQUIRED for AI features

# ── MCP Server ────────────────────────────────────────────────────────────────
# The MCP stdio server (mcp/gladius-context-server.js) uses these to call the
# Gladius REST API on behalf of an external AI agent (e.g. Claude Code).

# A Gladius API key (fos_ak_...) created in the UI under Settings → API Keys.
GLADIUS_API_KEY=                     # REQUIRED to run the MCP server

# Base URL of the running Gladius API. Defaults to http://localhost:3000.
GLADIUS_API_BASE_URL=http://localhost:3000

# Optional: cap the number of write-tool calls per MCP session (safety rail).
# GLADIUS_MCP_WRITE_RATE_LIMIT=50

# Gladius user ID that acts as the agent/automation identity (for audit trail).
# Used by: MCP server (add_comment, write_context_entry) and scripts/post-merge-sweep.js.
# Create a service user in the UI and set this to their numeric ID.
GLADIUS_AGENT_USER_ID=

# ── Search (NL translator rate limits) ────────────────────────────────────────
RATE_LIMIT_PER_USER_PER_MIN=30
RATE_LIMIT_PER_USER_PER_HOUR=200
SEARCH_TRANSLATE_USER_HOURLY=20
SEARCH_TRANSLATE_USER_DAILY_TOKENS=50000
SEARCH_TRANSLATE_INSTANCE_DAILY_TOKENS=500000

# ── Storage (attachments) ─────────────────────────────────────────────────────
GLADIUS_STORAGE_TYPE=local
GLADIUS_STORAGE_LOCAL_DIR=./uploads
GLADIUS_MAX_ATTACHMENT_MB=25

# ── Delivery worker (notifications) ──────────────────────────────────────────
DELIVERY_WORKER_POLL_INTERVAL_MS=5000
DELIVERY_WORKER_BATCH_SIZE=25
DELIVERY_WORKER_CONCURRENCY=5
NOTIFICATION_RETENTION_DAYS=90

# ── Tests ─────────────────────────────────────────────────────────────────────
# Used by integration tests — must match an org and work-item type in the DB.
GLADIUS_TEST_ORG_ID=
GLADIUS_TEST_WIT_TYPE_ID=
